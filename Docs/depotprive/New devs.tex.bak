\[ \pr{\intg{\R}{}{x}{|xf(x)|^2}}\pr{\intg{\R}{}{\xi}{|\xi\hat{f}(\xi)|^2}} \grand \pisur2\pr{\intg{R}{}{x}{|f(x)|^2}}^2. \]}

